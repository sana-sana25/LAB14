<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nom utilisateur"
            android:textStyle="bold"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Entrer votre nom"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Langue"
            android:textStyle="bold"
            android:textSize="16sp" />

        <Spinner
            android:id="@+id/spLang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Thème sombre"
                android:textStyle="bold"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/swDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Token sécurisé"
            android:textStyle="bold"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Entrer un token"
            android:inputType="textPassword"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnSavePrefs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sauvegarder prefs"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnLoadPrefs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Charger prefs"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSaveJson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sauvegarder fichier JSON"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnLoadJson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Charger fichier JSON"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Effacer"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:padding="10dp" />

    </LinearLayout>

</ScrollView>